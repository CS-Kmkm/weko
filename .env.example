INVENIO_WEB_HOST_NAME=repo.example.org
INVENIO_USER_EMAIL=admin@example.org
INVENIO_USER_PASS=change-this-admin-password
POSTGRES_PASSWORD=change-this-db-password
INVENIO_RABBITMQ_USER=weko
INVENIO_RABBITMQ_PASS=change-this-rabbitmq-password
INVENIO_RABBITMQ_VHOST=/
WEKO_CREATE_SAMPLE_USERS=False
WEKO_RECORDS_UI_SECRET_KEY=change-this-records-ui-secret
SECRET_KEY=change-this-flask-secret
WTF_CSRF_SECRET_KEY=change-this-csrf-secret
# Optional: pin a stable Docker Compose project name when needed.
# WEKO_DOCKER_PROJECT=weko3-local
WEKO_HTTP_PORT=18080
WEKO_HTTPS_PORT=443
WEKO_TLS_CERT_PATH=/absolute/path/to/fullchain.pem
WEKO_TLS_KEY_PATH=/absolute/path/to/privkey.pem
